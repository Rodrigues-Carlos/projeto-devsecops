# Copie para docker/.env e ajuste os valores. NUNCA versione o .env real.
# Segredo compartilhado para assinatura/validacao do JWT.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Banco de usuarios
POSTGRES_AUTH_USER=auth
POSTGRES_AUTH_PASSWORD=authpass
POSTGRES_AUTH_DB=usersdb

# Banco de agendamentos
POSTGRES_SCHED_USER=sched
POSTGRES_SCHED_PASSWORD=schedpass
POSTGRES_SCHED_DB=appointmentsdb

# Administrador inicial
ADMIN_EMAIL=admin@horamarcada.com
ADMIN_PASSWORD=Admin@12345
